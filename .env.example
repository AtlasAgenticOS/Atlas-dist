# =============================================================================
# Atlas environment template.  Copy to `.env` and fill in.
#   cp .env.example .env
# `.env` is gitignored - NEVER commit real secrets.  A fresh household generates
# its OWN secrets; never copy another instance's `.env` (its VAULT_MASTER_SECRET
# encrypts that household's stored credentials - sharing it cross-contaminates).
#
# Generate any secret with:  openssl rand -base64 32
# =============================================================================

# === REQUIRED - the stack will not boot without these ========================

# SQL Server 'sa' password (min 8 chars, upper+lower+digit+symbol).
MSSQL_SA_PASSWORD=YourStrong!Passw0rd

# JWT signing key.  openssl rand -base64 32
JWT_SECRET=

# Atlas internal API key (X-Api-Key for service-to-service calls).  openssl rand -base64 32
API_KEY=

# Credential-vault master secret - encrypts every user's stored IMAP/Home-Assistant/
# etc. credentials.  MUST be identical for the api AND worker services or startup throws.
# Set once, back it up: rotating it makes all stored credentials unreadable.  openssl rand -base64 32
VAULT_MASTER_SECRET=

# === RECOMMENDED - core features degrade without these =======================

# Public base URL, used in email links and returned to clients via /auth/bootstrap.
# Self-host default is localhost; set to your real hostname (Tailscale MagicDNS name,
# Cloudflare Tunnel hostname, or your domain) once remote access is configured.
APP_BASE_URL=http://localhost:8080/Atlas

# Anthropic key is normally set PER-USER in Settings (so each person bills their own),
# not here.  Only set a system-wide fallback key if you want one.
ANTHROPIC_API_KEY=

# SMTP (transactional email: verification, password reset).  Any provider.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_FROM_NAME=Atlas

# JWT issuer/audience - defaults are fine; only change if you know why.
JWT_ISSUER=Atlas
JWT_AUDIENCE=Atlas

# Superadmin/owner contact (optional; some admin notices use it).
ADMIN_EMAIL=

# Timezone for worker scheduled tasks (daily briefing hour, etc.).
TZ=America/New_York

# Environment (Development | Production).
ASPNETCORE_ENVIRONMENT=Production

# Docker image tag.
IMAGE_TAG=latest

# Host folder for Atlas's persistent data (SQL backups, vault, uploads, curriculum, downloads, etc.).
# Leave unset to use the default C:\Atlas. install.ps1 sets this and creates the subfolders.
ATLAS_DATA_ROOT=C:\Atlas

# Host folder the conversational-admin / it_coding CLI bridge operates in (your Atlas repo checkout).
# Leave unset to use the built-in default; set to wherever you cloned the repo on a self-host box.
CLI_BRIDGE_WORKDIR=C:\Atlas\repo

# === OPTIONAL - only needed for the matching plugin/integration ==============

# -- Distribution (downstream households) --
# The version to pull from public GHCR (default: latest). Pin a specific release if you want.
ATLAS_IMAGE_TAG=latest
# Public update feed + plugin marketplace (the Atlas-dist channel). Leave as-is for a normal
# install; these keep you off any single home server. The publisher (dev box) leaves them unset.
UPDATES_FEED_URL=https://raw.githubusercontent.com/AtlasAgenticOS/Atlas-dist/main/core-version.json
PLUGINS_REGISTRY_URL=https://raw.githubusercontent.com/AtlasAgenticOS/Atlas-dist/main/plugin-registry.json

# -- Push notifications (Android/desktop) - Firebase Cloud Messaging --
# Also mount your service-account JSON; see the docker-compose volume for the path.
FIREBASE_PROJECT_ID=

# -- SMS bridge (gmessages / Phone Link ingest) --
GMESSAGES_INGEST_SECRET=

# -- Embeddings / memory search (optional providers) --
VOYAGE_API_KEY=
HF_TOKEN=

# -- Billing (Stripe) - only if you charge for tiers --
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# -- Discord music bot (optional) --
DISCORD_TOKEN=
DISCORD_GUILD_IDS=
DISCORD_DEV_GUILD_ID=
DISCORD_OAUTH_CLIENT_ID=
DISCORD_OAUTH_CLIENT_SECRET=
LAVALINK_PASSWORD=youshallnotpass
ATLASBOT_PUBLIC_URL=
ATLAS_BOT_API_PORT=5085
ATLAS_BOT_HLS_PORT=8888
ATLAS_MUSIC_STREAM_TOKEN_SECRET=

# -- Music sources (optional; feed the bot) --
LAVASRC_SPOTIFY_ENABLED=false
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# -- Steam presence (optional) --
STEAM_API_KEY=

# -- Atlas Meet / calling - TURN relay (coturn), only for NAT-traversed calls --
TURN_HOST=
TURN_EXTERNAL_IP=
TURN_REALM=localhost
TURN_SECRET=
